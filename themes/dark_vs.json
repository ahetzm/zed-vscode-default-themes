{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Dark (Visual Studio)",
  "author": "Microsoft",
  "themes": [
    {
      "name": "Dark (Visual Studio)",
      "appearance": "dark",
      "style": {
        "background.appearance": "opaque",
        "accents": [
          "#007ACC"
        ],
        "background": "#1E1E1E",
        "drop_target.background": "#383B3D",
        "toolbar.background": "#1E1E1E",
        "scrollbar.track.background": "#1E1E1E",
        "editor.foreground": "#D4D4D4",
        "editor.background": "#1E1E1E",
        "editor.gutter.background": "#1E1E1E",
        "editor.active_line_number": "#D4D4D4",
        "hint": "#969696ff",
        "players": [],
        "syntax": {
          "attribute": {
            "color": "#9cdcfe"
          },
          "boolean": {
            "color": "#569cd6"
          },
          "comment": {
            "color": "#6A9955"
          },
          "comment.doc": {
            "color": "#6A9955"
          },
          "constant": {
            "color": "#569cd6"
          },
          "constructor": {
            "color": "#569cd6"
          },
          "embedded": {
            "color": "#D4D4D4"
          },
          "emphasis": {
            "color": "#C586C0",
            "font_style": "italic"
          },
          "emphasis.strong": {
            "color": "#569cd6",
            "font_weight": 700
          },
          "keyword": {
            "color": "#569cd6"
          },
          "number": {
            "color": "#b5cea8"
          },
          "operator": {
            "color": "#d4d4d4"
          },
          "preproc": {
            "color": "#569cd6"
          },
          "property": {
            "color": "#9cdcfe"
          },
          "punctuation": {
            "color": "#808080"
          },
          "punctuation.bracket": {
            "color": "#808080"
          },
          "punctuation.delimiter": {
            "color": "#808080"
          },
          "punctuation.list_marker": {
            "color": "#808080"
          },
          "punctuation.special": {
            "color": "#808080"
          },
          "string": {
            "color": "#ce9178"
          },
          "string.escape": {
            "color": "#ce9178"
          },
          "string.regex": {
            "color": "#d16969"
          },
          "string.special": {
            "color": "#ce9178"
          },
          "string.special.symbol": {
            "color": "#ce9178"
          },
          "tag": {
            "color": "#569cd6"
          },
          "text.literal": {
            "color": "#ce9178"
          },
          "variable": {
            "color": "#569cd6"
          },
          "variable.special": {
            "color": "#569cd6"
          },
          "variant": {
            "color": "#b5cea8"
          },
          "type.enum.member": {
            "color": "#b5cea8"
          }
        },
        "element.selected": "#0078d4",
        "ghost_element.selected": "#0078d4",
        "text.accent": "#ffffff"
      }
    }
  ]
}
