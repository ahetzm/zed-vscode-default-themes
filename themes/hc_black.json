{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Dark High Contrast",
  "author": "Microsoft",
  "themes": [
    {
      "name": "Dark High Contrast",
      "appearance": "dark",
      "style": {
        "background.appearance": "opaque",
        "accents": [],
        "background": "#000000",
        "toolbar.background": "#000000",
        "scrollbar.track.background": "#000000",
        "editor.foreground": "#FFFFFF",
        "editor.background": "#000000",
        "editor.gutter.background": "#000000",
        "editor.active_line_number": "#FFFFFF",
        "hint": "#969696ff",
        "players": [],
        "syntax": {
          "attribute": {
            "color": "#9cdcfe"
          },
          "boolean": {
            "color": "#569cd6"
          },
          "comment": {
            "color": "#7ca668"
          },
          "comment.doc": {
            "color": "#7ca668"
          },
          "constant": {
            "color": "#569cd6"
          },
          "constructor": {
            "color": "#4EC9B0"
          },
          "embedded": {
            "color": "#FFFFFF"
          },
          "function": {
            "color": "#DCDCAA"
          },
          "keyword": {
            "color": "#569cd6"
          },
          "number": {
            "color": "#b5cea8"
          },
          "operator": {
            "color": "#d4d4d4"
          },
          "preproc": {
            "color": "#569cd6"
          },
          "property": {
            "color": "#d4d4d4"
          },
          "punctuation": {
            "color": "#808080"
          },
          "punctuation.bracket": {
            "color": "#808080"
          },
          "punctuation.delimiter": {
            "color": "#808080"
          },
          "punctuation.list_marker": {
            "color": "#808080"
          },
          "punctuation.special": {
            "color": "#808080"
          },
          "string": {
            "color": "#ce9178"
          },
          "string.escape": {
            "color": "#569cd6"
          },
          "string.regex": {
            "color": "#d16969"
          },
          "string.special": {
            "color": "#ce9178"
          },
          "string.special.symbol": {
            "color": "#ce9178"
          },
          "tag": {
            "color": "#569cd6"
          },
          "text.literal": {
            "color": "#ce9178"
          },
          "type": {
            "color": "#4EC9B0"
          },
          "variable": {
            "color": "#9CDCFE"
          },
          "variable.special": {
            "color": "#9CDCFE"
          },
          "tag.component.jsx": {
            "color": "#4EC9B0"
          },
          "enum": {
            "color": "#4EC9B0"
          },
          "type.enum": {
            "color": "#4EC9B0"
          }
        }
      }
    }
  ]
}
